{
  "manifest_version": 3,
  "name": "My Bookmarks",
  "version": "1.1.0",
  "description": "Save bookmarks to your personal My Bookmarks server",
  "permissions": ["activeTab", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "my-bookmarks@localhost",
      "strict_min_version": "109.0"
    }
  }
}
