{
  "name": "my-bookmarks-backend",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "migration:run": "sequelize-cli db:migrate --config src/config/database.js --migrations-path src/migrations",
    "migration:undo": "sequelize-cli db:migrate:undo --config src/config/database.js --migrations-path src/migrations"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "multer": "^2.1.1",
    "nest-winston": "^1.9.4",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sequelize": "^6.35.0",
    "sequelize-typescript": "^2.1.6",
    "sqlite3": "^5.1.6",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^3.0.13",
    "@types/sequelize": "^4.28.19",
    "sequelize-cli": "^6.6.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
